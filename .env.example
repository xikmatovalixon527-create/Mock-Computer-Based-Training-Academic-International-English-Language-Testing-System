# Database Connection String (Direct Neon Connection or similar Postgres provider)
DATABASE_URL=postgresql://your_db_username:your_secure_password@your_neon_host.neon.tech/your_db_name?sslmode=require

# Secure Random JWT Key (Must be at least 32 characters long to avoid warnings)
JWT_SECRET=secure_production_only_jwt_secret_key_generator_32_characters

# Supabase REST Credentials (Used by supabaseAdmin client)
NEXT_PUBLIC_SUPABASE_URL=https://your_supabase_project_id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_keep_absolutely_private